# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=treysson_trimz
DB_USER=postgres
DB_PASSWORD=8080

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
# → Generate new private key (downloads a JSON file)
# Copy the values from that JSON file into these variables:

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Paste the private key exactly — keep the quotes and \n characters
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
